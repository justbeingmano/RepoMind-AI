# Copy to .env.local to override.
#
# Development (see .env.development): VITE_API_URL=/api uses Vite proxy.
# Production build: defaults to http://127.0.0.1:8000 unless you set:
# VITE_API_URL=http://127.0.0.1:8000
#
# Backend (optional):
# DEBUG=true          — enable /docs and /redoc (default: true)
# CORS_ORIGINS=...    — comma-separated allowed origins
# GITHUB_TOKEN=...    — for scraper.py only
